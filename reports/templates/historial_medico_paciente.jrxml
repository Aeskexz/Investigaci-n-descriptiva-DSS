<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="historial_medico_paciente" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail" uuid="d257cc95-611b-4ddf-a8de-7da2da6d8f31">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value=""/>
    <parameter name="P_PACIENTE_ID" class="java.lang.String"/>
    <parameter name="P_PACIENTE_NOMBRE" class="java.lang.String"/>
    <parameter name="P_PACIENTE_EMAIL" class="java.lang.String"/>
    <parameter name="P_PACIENTE_TELEFONO" class="java.lang.String"/>
    <parameter name="P_GENERADO_POR" class="java.lang.String"/>
    <parameter name="P_GENERADO_EN" class="java.lang.String"/>
    <queryString language="xPath"><![CDATA[/reporte/entradas/entrada]]></queryString>
    <field name="fecha_consulta" class="java.lang.String">
        <fieldDescription><![CDATA[fecha_consulta]]></fieldDescription>
    </field>
    <field name="doctor_nombre" class="java.lang.String">
        <fieldDescription><![CDATA[doctor_nombre]]></fieldDescription>
    </field>
    <field name="sintomas" class="java.lang.String">
        <fieldDescription><![CDATA[sintomas]]></fieldDescription>
    </field>
    <field name="diagnostico" class="java.lang.String">
        <fieldDescription><![CDATA[diagnostico]]></fieldDescription>
    </field>
    <field name="tratamiento" class="java.lang.String">
        <fieldDescription><![CDATA[tratamiento]]></fieldDescription>
    </field>
    <field name="notas" class="java.lang.String">
        <fieldDescription><![CDATA[notas]]></fieldDescription>
    </field>
    <title>
        <band height="95">
            <staticText>
                <reportElement x="0" y="0" width="535" height="24"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Informe de Historial Medico]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="30" width="260" height="16"/>
                <textFieldExpression><![CDATA["Paciente: " + $P{P_PACIENTE_NOMBRE} + " (" + $P{P_PACIENTE_ID} + ")"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="48" width="300" height="14"/>
                <textFieldExpression><![CDATA["Email: " + $P{P_PACIENTE_EMAIL} + "  Telefono: " + $P{P_PACIENTE_TELEFONO}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="66" width="535" height="14"/>
                <textFieldExpression><![CDATA["Generado por: " + $P{P_GENERADO_POR} + " | " + $P{P_GENERADO_EN}]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="95" height="20" mode="Opaque" backcolor="#E8EEF7"/>
                <textElement verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Fecha]]></text>
            </staticText>
            <staticText>
                <reportElement x="95" y="0" width="120" height="20" mode="Opaque" backcolor="#E8EEF7"/>
                <textElement verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Doctor]]></text>
            </staticText>
            <staticText>
                <reportElement x="215" y="0" width="320" height="20" mode="Opaque" backcolor="#E8EEF7"/>
                <textElement verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Resumen Clinico]]></text>
            </staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="82" splitType="Stretch">
            <textField isStretchWithOverflow="true">
                <reportElement x="0" y="0" width="95" height="18"/>
                <textFieldExpression><![CDATA[$F{fecha_consulta}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="95" y="0" width="120" height="18"/>
                <textFieldExpression><![CDATA[$F{doctor_nombre}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="215" y="0" width="320" height="78"/>
                <textElement>
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Sintomas: " + ($F{sintomas} == null ? "" : $F{sintomas}) + "\nDiagnostico: " + ($F{diagnostico} == null ? "" : $F{diagnostico}) + "\nTratamiento: " + ($F{tratamiento} == null ? "" : $F{tratamiento}) + "\nNotas: " + ($F{notas} == null ? "" : $F{notas})]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    <noData>
        <band height="40">
            <staticText>
                <reportElement x="0" y="10" width="535" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[No hay entradas en el historial medico para este paciente.]]></text>
            </staticText>
        </band>
    </noData>
</jasperReport>